# SEO Configuration
# Copy this file to .env.local and fill in your actual values

# Website Information
NEXT_PUBLIC_SITE_NAME="Your Business Name"
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SITE_DESCRIPTION="Your business description for SEO"

# Business Information (for Schema.org)
NEXT_PUBLIC_BUSINESS_NAME="Your Business Name"
NEXT_PUBLIC_BUSINESS_TYPE="ProfessionalService"  # or LocalBusiness, Organization, etc.
NEXT_PUBLIC_BUSINESS_PHONE="+1-XXX-XXX-XXXX"
NEXT_PUBLIC_BUSINESS_EMAIL="info@yourbusiness.com"
NEXT_PUBLIC_BUSINESS_ADDRESS_STREET="123 Main Street"
NEXT_PUBLIC_BUSINESS_ADDRESS_CITY="Your City"
NEXT_PUBLIC_BUSINESS_ADDRESS_STATE="Your State"
NEXT_PUBLIC_BUSINESS_ADDRESS_ZIP="12345"
NEXT_PUBLIC_BUSINESS_ADDRESS_COUNTRY="US"

# Social Media Links
NEXT_PUBLIC_FACEBOOK_URL="https://facebook.com/yourpage"
NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/yourpage"
NEXT_PUBLIC_TWITTER_URL="https://twitter.com/yourpage"
NEXT_PUBLIC_LINKEDIN_URL="https://linkedin.com/company/yourpage"
NEXT_PUBLIC_YOUTUBE_URL="https://youtube.com/@yourpage"
NEXT_PUBLIC_TIKTOK_URL="https://tiktok.com/@yourpage"
NEXT_PUBLIC_PINTEREST_URL="https://pinterest.com/yourpage"

# Analytics & Tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"  # Google Analytics 4 ID
NEXT_PUBLIC_FB_PIXEL_ID=""  # Facebook Pixel ID (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""  # Google Search Console verification code

# Open Graph Image (default share image)
NEXT_PUBLIC_OG_IMAGE="/images/og-default.jpg"
